#!/bin/bash
set -euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://www.erikdubois.be
# Youtube   : https://youtube.com/erikdubois
##################################################################################################################

RESET=$(tput sgr0)
CYAN=$(tput setaf 6)
GREEN=$(tput setaf 2)
RED=$(tput setaf 1)
YELLOW=$(tput setaf 3)

separator() { echo "${CYAN}================================================================${RESET}"; }
header()    { separator; echo "${CYAN}  $1${RESET}"; separator; }
success()   { echo "${GREEN}[OK]  $1${RESET}"; }
info()      { echo "${CYAN}[>>]  $1${RESET}"; }
warn()      { echo "${YELLOW}[!!]  $1${RESET}"; }
error()     { echo "${RED}[XX]  $1${RESET}"; }

BUILD_USER=${1:-$SUDO_USER}

header "Building yay-git from AUR — build user: $BUILD_USER"

header "Installing build dependencies"
pacman -S --needed --noconfirm base-devel git
success "Dependencies ready"

if [ -d /tmp/yay-git ]; then
    warn "Removing existing /tmp/yay-git"
    rm -rf /tmp/yay-git
fi

header "Cloning yay-git from AUR"
if ! sudo -u "$BUILD_USER" git clone https://aur.archlinux.org/yay-git.git /tmp/yay-git; then
    error "git clone failed"
    read -p "Press Enter to close..."
    exit 1
fi
success "Clone complete"

header "Building and installing yay-git"
cd /tmp/yay-git && sudo -u "$BUILD_USER" makepkg -si --noconfirm
success "yay-git installed"

read -p "Press Enter to close..."
