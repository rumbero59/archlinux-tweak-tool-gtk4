#!/bin/bash
set -euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://www.erikdubois.be
# Youtube   : https://youtube.com/erikdubois
##################################################################################################################

RESET=$(tput sgr0)
CYAN=$(tput setaf 6)
GREEN=$(tput setaf 2)
RED=$(tput setaf 1)
YELLOW=$(tput setaf 3)

separator() { echo "${CYAN}$(printf '─%.0s' {1..72})${RESET}"; }
header()    { echo; separator; echo "${CYAN}  $*${RESET}"; separator; }
success()   { echo "${GREEN}  [ok]  $*${RESET}"; }
info()      { echo "${CYAN}  [..]  $*${RESET}"; }
warn()      { echo "${YELLOW}  [!!]  $*${RESET}"; }
error()     { echo "${RED}  [EE]  $*${RESET}"; }

header "Hardware Probe"

# ── Install hw-probe if missing ───────────────────────────────────────────────
header "Checking hw-probe"
if ! pacman -Qi hw-probe &>/dev/null; then
    info "hw-probe not installed — attempting install..."
    if ! pacman -S --noconfirm --needed hw-probe; then
        error "hw-probe not found in enabled repos."
        error "Enable chaotic-AUR first (ATT > Pacman tab > Chaotic-AUR switch)."
        read -rp "Press Enter to close..."
        exit 1
    fi
    success "hw-probe installed"
else
    info "hw-probe already installed"
fi

# ── Run probe and upload ──────────────────────────────────────────────────────
header "Running Hardware Probe and Uploading"
info "This will collect hardware info and upload to linux-hardware.org..."
/usr/bin/hw-probe -all -upload
success "Hardware probe complete — copy the URL above"

read -rp "Press Enter to close..."
