#!/bin/bash
set -euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://kiroproject.be
# Youtube   : https://youtube.com/erikdubois
##################################################################################################################

RESET=$(tput sgr0)
CYAN=$(tput setaf 6)
GREEN=$(tput setaf 2)
RED=$(tput setaf 1)
YELLOW=$(tput setaf 3)

separator() {
    echo "${CYAN}===============================================================================${RESET}"
}

header() {
    echo ""
    separator
    echo "${CYAN}  $1${RESET}"
    separator
}

success() { echo "${GREEN}  ✓ $1${RESET}"; }
info()    { echo "    $1"; }
warn()    { echo "${YELLOW}  ⚠ $1${RESET}"; }
error()   { echo "${RED}  ✗ $1${RESET}"; }
trap 'error "Command failed at line $LINENO"' ERR

DEBUG=false
for arg in "$@"; do [[ "$arg" == "--debug" ]] && DEBUG=true; done

USERNAME="${SUDO_USER:-$(logname 2>/dev/null || echo '')}"
DEST="/etc/att/current_desktop"

# ── Detect desktop ─────────────────────────────────────────────────────────────
header "Detecting desktop environment for user: $USERNAME"

if [ -z "$USERNAME" ]; then
    error "Cannot determine real username (SUDO_USER unset and logname failed)"
    exit 1
fi

mkdir -p /etc/att

DESKTOP=""
SOURCE_VAR=""
for environ_file in /proc/[0-9]*/environ; do
    owner=$(stat -c %U "$environ_file" 2>/dev/null) || continue
    [ "$owner" = "$USERNAME" ] || continue
    env_block=$(tr '\0' '\n' < "$environ_file" 2>/dev/null) || continue
    for var in XDG_CURRENT_DESKTOP DESKTOP_SESSION XDG_SESSION_DESKTOP; do
        val=$(echo "$env_block" | grep "^${var}=" | cut -d= -f2-) || continue
        if [ -n "$val" ]; then
            DESKTOP="${val,,}"
            SOURCE_VAR="$var"
            break
        fi
    done
    [ -n "$DESKTOP" ] && break
done

if [ -n "$DESKTOP" ]; then
    echo "$DESKTOP" > "$DEST"
    $DEBUG && info "Source: $SOURCE_VAR"
    $DEBUG && success "Desktop detected: $DESKTOP — written to $DEST"
else
    warn "No desktop variable found in any process owned by $USERNAME; $DEST unchanged"
fi
