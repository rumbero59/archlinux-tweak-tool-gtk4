#!/bin/bash
set -euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://www.erikdubois.be
# Youtube   : https://youtube.com/erikdubois
##################################################################################################################

RESET=$(tput sgr0)
CYAN=$(tput setaf 6)
GREEN=$(tput setaf 2)
RED=$(tput setaf 1)
YELLOW=$(tput setaf 3)

separator() { echo "${CYAN}$(printf '─%.0s' {1..72})${RESET}"; }
header()    { echo; separator; echo "${CYAN}  $*${RESET}"; separator; }
success()   { echo "${GREEN}  [ok]  $*${RESET}"; }
info()      { echo "${CYAN}  [..]  $*${RESET}"; }
warn()      { echo "${YELLOW}  [!!]  $*${RESET}"; }
error()     { echo "${RED}  [EE]  $*${RESET}"; }
trap 'error "Command failed at line $LINENO"' ERR

MIRRORLIST=/etc/pacman.d/mirrorlist

header "Set Mainstream Arch Mirrors"
info "Target: $MIRRORLIST"

# ── Write mirrorlist ──────────────────────────────────────────────────────────
header "Writing Mirrorlist"
sudo tee "$MIRRORLIST" > /dev/null << 'EOF'
Server = https://geo.mirror.pkgbuild.com/$repo/os/$arch
Server = http://mirror.rackspace.com/archlinux/$repo/os/$arch
Server = https://mirror.rackspace.com/archlinux/$repo/os/$arch
Server = https://mirrors.kernel.org/archlinux/$repo/os/$arch
Server = https://mirror.osbeck.com/archlinux/$repo/os/$arch
Server = http://mirror.osbeck.com/archlinux/$repo/os/$arch
EOF
success "Mirrorlist written to $MIRRORLIST"

header "Mirrorlist Contents"
cat "$MIRRORLIST"

read -rp "Press Enter to close..."
