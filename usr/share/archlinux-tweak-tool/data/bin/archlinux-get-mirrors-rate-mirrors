#!/bin/bash
set -euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://kiroproject.be
# Youtube   : https://youtube.com/erikdubois
##################################################################################################################

RESET=$(tput sgr0)
CYAN=$(tput setaf 6)
GREEN=$(tput setaf 2)
RED=$(tput setaf 1)
YELLOW=$(tput setaf 3)

separator() { echo "${CYAN}────────────────────────────────────────────────────────────${RESET}"; }
header()    { separator; echo "${CYAN}  $*${RESET}"; separator; }
success()   { echo "${GREEN}  [OK]  $*${RESET}"; }
info()      { echo "  [..] $*"; }
warn()      { echo "${YELLOW}  [!!] $*${RESET}"; }
error()     { echo "${RED}  [EE] $*${RESET}"; }
trap 'error "Command failed at line $LINENO"' ERR

header "Ranking Arch mirrors with rate-mirrors"
info "Writing result to /etc/pacman.d/mirrorlist ..."

rate-mirrors --allow-root arch | sudo tee /etc/pacman.d/mirrorlist

success "Mirrorlist updated — you can close this window"

read -rp "Press Enter to close..."
