#!/bin/bash
set -euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://kiroproject.be
# Youtube   : https://youtube.com/erikdubois
##################################################################################################################

RESET=$(tput sgr0)
CYAN=$(tput setaf 6)
GREEN=$(tput setaf 2)
RED=$(tput setaf 1)
YELLOW=$(tput setaf 3)

separator() {
    echo "${CYAN}===============================================================================${RESET}"
}

header() {
    echo ""
    separator
    echo "${CYAN}  $1${RESET}"
    separator
}

success() { echo "${GREEN}  ✓ $1${RESET}"; }
info()    { echo "    $1"; }
warn()    { echo "${YELLOW}  ⚠ $1${RESET}"; }
error()   { echo "${RED}  ✗ $1${RESET}"; }

# ── What is skel? ─────────────────────────────────────────────────────────────
header "Skel — Restore Default Configuration from /etc/skel"
info "New configurations are placed in /etc/skel but are not applied automatically."
info "Skel copies those defaults into your home directory so they take effect."
info ""
info "Before copying, skel backs up your ~/.config folder with a timestamp."
info "It will overwrite your current settings — that is its purpose."
info ""
info "Use skel to recover from a broken tiling window manager config:"
info "  type 'skel' in a terminal or TTY to restore known-good defaults."

# ── Confirmation ──────────────────────────────────────────────────────────────
header "Confirmation"
info "Copy /etc/skel contents to your home directory? (y/n)"
echo ""
read -r response

if [[ "$response" == [yY] ]]; then

    time=$(date +%Y.%m.%d-%H.%M.%S)

    # ── Ensure ~/.config exists ────────────────────────────────────────────────
    header "Ensuring ~/.config Exists"
    if [ ! -d ~/.config ]; then
        mkdir ~/.config
        success "Created ~/.config"
    else
        info "~/.config already exists"
    fi

    # ── Backup ~/.config ───────────────────────────────────────────────────────
    header "Backing Up ~/.config"
    info "Destination: ~/.config-backup-$time"
    warn "Large .config folders may take a moment — please be patient."
    cp -Rf ~/.config ~/.config-backup-"$time"
    success "Backup created: ~/.config-backup-$time"

    # ── Copy /etc/skel to home ─────────────────────────────────────────────────
    header "Copying /etc/skel to Home Directory"
    warn "Large /etc/skel folders may take a moment — please be patient."
    cp -r /etc/skel/. "$HOME"
    success "Defaults applied from /etc/skel"

    # ── Done ───────────────────────────────────────────────────────────────────
    echo ""
    separator
    echo "${GREEN}  DONE — you can close this window${RESET}"
    separator
    echo ""

else

    echo ""
    separator
    warn "Nothing has been changed."
    separator
    echo ""

fi
