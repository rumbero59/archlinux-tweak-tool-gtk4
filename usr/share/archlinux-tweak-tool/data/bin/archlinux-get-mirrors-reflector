#!/bin/bash
set -euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://kiroproject.be
# Youtube   : https://youtube.com/erikdubois
##################################################################################################################

RESET=$(tput sgr0)
CYAN=$(tput setaf 6)
GREEN=$(tput setaf 2)
RED=$(tput setaf 1)
YELLOW=$(tput setaf 3)

separator() { echo "${CYAN}$(printf '─%.0s' {1..72})${RESET}"; }
header()    { echo; separator; echo "${CYAN}  $*${RESET}"; separator; }
success()   { echo "${GREEN}  [ok]  $*${RESET}"; }
info()      { echo "${CYAN}  [..]  $*${RESET}"; }
warn()      { echo "${YELLOW}  [!!]  $*${RESET}"; }
error()     { echo "${RED}  [EE]  $*${RESET}"; }
trap 'error "Command failed at line $LINENO"' ERR

header "Update Mirrorlist — reflector"
info "Fetching top 10 fastest HTTPS mirrors synced within 12h (scored from top 100)..."
sudo /usr/bin/reflector --score 100 --fastest 10 --number 10 --protocol https --age 12 --verbose --save /etc/pacman.d/mirrorlist
success "Mirrorlist updated at /etc/pacman.d/mirrorlist"

read -rp "Press Enter to close..."
