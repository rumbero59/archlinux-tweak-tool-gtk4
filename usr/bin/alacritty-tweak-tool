#!/bin/bash
set -euo pipefail

RESET=$(tput sgr0 2>/dev/null || echo "")
CYAN=$(tput setaf 6 2>/dev/null || echo "")
GREEN=$(tput setaf 2 2>/dev/null || echo "")
RED=$(tput setaf 1 2>/dev/null || echo "")
YELLOW=$(tput setaf 3 2>/dev/null || echo "")

separator() { echo "${CYAN}===============================================================================${RESET}"; }
header()    { echo ""; separator; echo "${CYAN}  $1${RESET}"; separator; }
success()   { echo "${GREEN}  ✓ $1${RESET}"; }
info()      { echo "    $1"; }
warn()      { echo "${YELLOW}  ⚠ $1${RESET}"; }
error()     { echo "${RED}  ✗ $1${RESET}"; }

header "Alacritty Tweak Tool"

if ! command -v python3 &>/dev/null; then
    error "python3 not found — please install it"
    exit 1
fi

if ! python3 -c "import tomlkit" &>/dev/null; then
    warn "python-tomlkit not installed — install it with: sudo pacman -S python-tomlkit"
    exit 1
fi

if ! python3 -c "import gi; gi.require_version('Vte', '3.91'); from gi.repository import Vte" &>/dev/null; then
    warn "vte3 not available — install it with: sudo pacman -S vte3"
    exit 1
fi

info "Starting Alacritty Tweak Tool..."
exec python3 /usr/share/alacritty-tweak-tool/alacritty-tweak-tool.py "$@"
