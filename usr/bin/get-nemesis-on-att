#!/bin/bash
set -euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://kiroproject.be
# Youtube   : https://youtube.com/erikdubois
##################################################################################################################

RESET=$(tput sgr0)
CYAN=$(tput setaf 6)
GREEN=$(tput setaf 2)
RED=$(tput setaf 1)
YELLOW=$(tput setaf 3)

separator() {
    echo "${CYAN}===============================================================================${RESET}"
}

header() {
    echo ""
    separator
    echo "${CYAN}  $1${RESET}"
    separator
}

success() { echo "${GREEN}  ✓ $1${RESET}"; }
info()    { echo "    $1"; }
warn()    { echo "${YELLOW}  ⚠ $1${RESET}"; }
error()   { echo "${RED}  ✗ $1${RESET}"; }

trap 'error "Command failed at line $LINENO"' ERR

# ── Header ────────────────────────────────────────────────────────────────────
header "Get Nemesis on ATT"

# ── Ensure ~/DATA exists ──────────────────────────────────────────────────────
header "Ensuring ~/DATA Directory Exists"
if [ -d "$HOME/DATA" ]; then
    info "Directory already exists: $HOME/DATA"
else
    mkdir -p "$HOME/DATA"
    success "Directory created: $HOME/DATA"
fi

# ── Clone arcolinux-nemesis ───────────────────────────────────────────────────
header "Cloning arcolinux-nemesis"
info "Target: $HOME/DATA/arcolinux-nemesis"
cd "$HOME/DATA"
if [ -d "$HOME/DATA/arcolinux-nemesis" ]; then
    warn "Repository already exists — skipping clone"
    info "Remove $HOME/DATA/arcolinux-nemesis first if you want a fresh copy"
else
    git clone https://github.com/erikdubois/arcolinux-nemesis
    success "Repository cloned to $HOME/DATA/arcolinux-nemesis"
fi

# ── Done ──────────────────────────────────────────────────────────────────────
echo ""
separator
echo "${GREEN}  DONE${RESET}"
separator
echo ""
read -p "  Close this window when you are ready..."
