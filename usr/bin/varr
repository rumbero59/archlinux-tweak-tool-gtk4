#!/bin/bash
set -euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://www.erikdubois.be
# Youtube   : https://youtube.com/erikdubois
##################################################################################################################

RESET=$(tput sgr0)
CYAN=$(tput setaf 6)
GREEN=$(tput setaf 2)
RED=$(tput setaf 1)
YELLOW=$(tput setaf 3)

separator() { echo ""; echo "${CYAN}################################################################################${RESET}"; echo ""; }
header()  { echo ""; echo "${CYAN}################################################################################${RESET}"; echo "  $1"; echo "${CYAN}################################################################################${RESET}"; echo ""; }
success() { echo "${GREEN}[SUCCESS] $1${RESET}"; }
info()    { echo "${CYAN}[INFO]    $1${RESET}"; }
warn()    { echo "${YELLOW}[WARN]    $1${RESET}"; }
error()   { echo "${RED}[ERROR]   $1${RESET}"; }

LOCAL_CONF="/usr/share/archlinux-tweak-tool/data/variety/variety.conf"

header "Reinstalling default variety config"

if [[ ! -f "$LOCAL_CONF" ]]; then
    error "Local variety.conf not found at $LOCAL_CONF"
    exit 1
fi

mkdir -p ~/.config/variety
cp "$LOCAL_CONF" ~/.config/variety/variety.conf
success "Default variety config is in place"
