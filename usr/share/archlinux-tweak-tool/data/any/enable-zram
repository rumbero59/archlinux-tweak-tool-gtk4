##################################################################################################################
# Usage: enable-zram <size>   e.g. enable-zram "ram / 2"
# Size is passed as a zram-generator expression: ram/2, ram*3/4, 4096, etc.
##################################################################################################################

SIZE=${1:-"ram / 2"}
ZRAM_CONF=/etc/systemd/zram-generator.conf

tput setaf 6
echo "================================================================"
echo "  Enabling zram with size: $SIZE"
echo "================================================================"
tput sgr0

# Install zram-generator if not present
if ! command -v zram-generator &>/dev/null && ! pacman -Qi zram-generator &>/dev/null; then
    tput setaf 2
    echo "Installing zram-generator..."
    tput sgr0
    pacman -S zram-generator --noconfirm --needed
fi

echo "Writing $ZRAM_CONF..."
cat > "$ZRAM_CONF" << EOF
[zram0]
zram-size = $SIZE
compression-algorithm = zstd
EOF

echo "Reloading systemd daemon..."
systemctl daemon-reload

echo "Starting zram device..."
systemctl start systemd-zram-setup@zram0.service

echo
tput setaf 2
echo "================================================================"
echo "  zram enabled successfully"
echo "================================================================"
tput sgr0
swapon --show
echo
cat "$ZRAM_CONF"
echo
echo "###############################################################################"
echo "###                DONE - YOU CAN CLOSE THIS WINDOW                        ####"
echo "###############################################################################"
