#!/bin/bash
set -euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://kiroproject.be
# Youtube   : https://youtube.com/erikdubois
##################################################################################################################

RESET=$(tput sgr0)
CYAN=$(tput setaf 6)
GREEN=$(tput setaf 2)
RED=$(tput setaf 1)
YELLOW=$(tput setaf 3)

separator() {
    echo "${CYAN}===============================================================================${RESET}"
}

header() {
    echo ""
    separator
    echo "${CYAN}  $1${RESET}"
    separator
}

success() { echo "${GREEN}  ✓ $1${RESET}"; }
info()    { echo "    $1"; }
warn()    { echo "${YELLOW}  ⚠ $1${RESET}"; }
error()   { echo "${RED}  ✗ $1${RESET}"; }

# ── Header ─────────────────────────────────────────────────────────────────────
header "Fix SDDM Configuration"

# ── Ensure /etc/sddm.conf.d exists ────────────────────────────────────────────
header "Ensuring /etc/sddm.conf.d Directory Exists"
if [ -d /etc/sddm.conf.d/ ]; then
    info "Directory already exists"
else
    sudo mkdir -p /etc/sddm.conf.d/
    success "Directory created: /etc/sddm.conf.d/"
fi

# ── Backup kde_settings.conf ──────────────────────────────────────────────────
header "Backing Up kde_settings.conf"
if [ -f /etc/sddm.conf.d/kde_settings.conf ]; then
    if [ ! -f /etc/kde_settings.conf-bak ]; then
        sudo cp -p /etc/sddm.conf.d/kde_settings.conf /etc/kde_settings.conf-bak
        success "Backup created: /etc/kde_settings.conf-bak"
    else
        info "Backup already exists — skipping"
    fi
else
    info "No existing kde_settings.conf — skipping backup"
fi

# ── Backup /etc/sddm.conf ─────────────────────────────────────────────────────
header "Backing Up /etc/sddm.conf"
if [ -f /etc/sddm.conf ]; then
    if [ ! -f /etc/sddm.conf.bak ]; then
        sudo cp -p /etc/sddm.conf /etc/sddm.conf.bak
        success "Backup created: /etc/sddm.conf.bak"
    else
        info "Backup already exists — skipping"
    fi
else
    info "No existing /etc/sddm.conf — skipping backup"
fi

# ── Install ATT sddm.conf ─────────────────────────────────────────────────────
header "Installing ATT sddm.conf"
info "Source: /usr/share/archlinux-tweak-tool/data/sddm/sddm.conf"
info "Target: /etc/sddm.conf"
sudo cp -v /usr/share/archlinux-tweak-tool/data/sddm/sddm.conf /etc/sddm.conf
success "sddm.conf installed"

# ── Install ATT kde_settings.conf ─────────────────────────────────────────────
header "Installing ATT kde_settings.conf"
info "Source: /usr/share/archlinux-tweak-tool/data/sddm.conf.d/kde_settings.conf"
info "Target: /etc/sddm.conf.d/kde_settings.conf"
sudo cp -v /usr/share/archlinux-tweak-tool/data/sddm.conf.d/kde_settings.conf /etc/sddm.conf.d/kde_settings.conf
success "kde_settings.conf installed"

# ── Done ──────────────────────────────────────────────────────────────────────
echo ""
separator
echo "${GREEN}  DONE — you can close this window${RESET}"
separator
echo ""
