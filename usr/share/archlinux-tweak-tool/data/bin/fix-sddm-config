#!/bin/bash
set -euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://www.erikdubois.be
# Youtube   : https://youtube.com/erikdubois
##################################################################################################################

RESET=$(tput sgr0)
CYAN=$(tput setaf 6)
GREEN=$(tput setaf 2)
RED=$(tput setaf 1)
YELLOW=$(tput setaf 3)

DATA_DIR="/usr/share/archlinux-tweak-tool/data/sddm"
SDDM_CONF="/etc/sddm.conf"
SDDM_KDE="/etc/sddm.conf.d/kde_settings.conf"
GITHUB_BASE="https://raw.githubusercontent.com/kirodubes/kiro-iso/refs/heads/main/archiso/airootfs"

separator() {
    echo "${CYAN}===============================================================================${RESET}"
}

header() {
    echo ""
    separator
    echo "${CYAN}  $1${RESET}"
    separator
}

success() { echo "${GREEN}  ✓ $1${RESET}"; }
info()    { echo "    $1"; }
warn()    { echo "${YELLOW}  ⚠ $1${RESET}"; }
error()   { echo "${RED}  ✗ $1${RESET}"; }

# ── Header ────────────────────────────────────────────────────────────────────
header "Fix SDDM Configuration"

# ── Internet check ─────────────────────────────────────────────────────────────
header "Checking Internet Connectivity"
Online=0
if ping -c 1 8.8.8.8 > /dev/null 2>&1; then
    success "Internet connection available"
    Online=1
else
    warn "No internet connection — will use local files"
fi

# ── File check ─────────────────────────────────────────────────────────────────
header "Checking Existing SDDM Configuration"
if [[ -f "$SDDM_CONF" ]]; then
    success "$SDDM_CONF found"
else
    warn "$SDDM_CONF not found"
fi
if [[ -f "$SDDM_KDE" ]]; then
    success "$SDDM_KDE found"
else
    warn "$SDDM_KDE not found"
fi

# ── Backup existing files ──────────────────────────────────────────────────────
header "Creating Backups"
if [[ -f "$SDDM_CONF" ]]; then
    if [[ ! -f "${SDDM_CONF}.bak" ]]; then
        sudo cp -p "$SDDM_CONF" "${SDDM_CONF}.bak"
        success "Backup created: ${SDDM_CONF}.bak"
    else
        info "Backup already exists: ${SDDM_CONF}.bak — skipping"
    fi
fi
if [[ -f "$SDDM_KDE" ]]; then
    if [[ ! -f /etc/kde_settings.conf-bak ]]; then
        sudo cp -p "$SDDM_KDE" /etc/kde_settings.conf-bak
        success "Backup created: /etc/kde_settings.conf-bak"
    else
        info "Backup already exists: /etc/kde_settings.conf-bak — skipping"
    fi
fi

# ── Helper functions ───────────────────────────────────────────────────────────
patch_live_user_settings() {
    info "Removing live-user specific settings..."
    sed -i "s/Session=xfce/#Session=/g" "$SDDM_KDE" 2>/dev/null
    sed -i "s/User=liveuser/#User=/g"   "$SDDM_KDE" 2>/dev/null
    success "Live-user settings cleared from $SDDM_KDE"
}

apply_local() {
    info "Copying from local ATT data ($DATA_DIR)..."
    if cp "$DATA_DIR/sddm.conf" "$SDDM_CONF" 2>/dev/null &&
       cp "$DATA_DIR/kde_settings.conf" "$SDDM_KDE" 2>/dev/null; then
        success "Copied $SDDM_CONF"
        success "Copied $SDDM_KDE"
        patch_live_user_settings
    else
        error "Local files not found in $DATA_DIR"
        error "Nothing was changed"
    fi
}

apply_online() {
    info "Downloading from GitHub..."
    if wget -q "$GITHUB_BASE/etc/sddm.conf" -O "$SDDM_CONF" &&
       wget -q "$GITHUB_BASE/etc/sddm.conf.d/kde_settings.conf" -O "$SDDM_KDE"; then
        success "Downloaded $SDDM_CONF"
        success "Downloaded $SDDM_KDE"
        patch_live_user_settings
    else
        error "Download failed — falling back to local files"
        apply_local
    fi
}

# ── Apply ──────────────────────────────────────────────────────────────────────
header "Applying SDDM Configuration"
if [[ $Online -eq 1 ]]; then
    apply_online
else
    apply_local
fi

# ── Done ───────────────────────────────────────────────────────────────────────
success "Done — you can close this window"
read -rp "  Press Enter to close..."
