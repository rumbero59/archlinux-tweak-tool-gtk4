#!/bin/bash
set -Euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://kiroproject.be
##################################################################################################################
#
#   DO NOT JUST RUN THIS. EXAMINE AND JUDGE. RUN AT YOUR OWN RISK.
#
#   Purpose:
#   Copies /etc/skel/ into the current user's home directory. Before copying,
#   it backs up ONLY the ~/.config entries that /etc/skel/.config will
#   overwrite — not the whole ~/.config (which can be many GB of browser/app
#   cache). The /etc/skel copy step still overwrites everything (overwrite all).
#
#   Why: backing up all of ~/.config got slow as caches grew. The only data
#   actually at risk is what /etc/skel overwrites, so that is the only thing
#   worth backing up — making this the fast default. For a full ~/.config
#   backup, use the sibling kiro-skell-all.
#
#   Self-contained by design: this script does NOT source
#   /usr/local/lib/kiro-common.sh. It inlines the handful of helpers it needs
#   so it runs unchanged on any distro (the library is Kiro-only). All
#   user-facing text uses "$(basename "$0")", so a verbatim copy under a
#   different filename prints its own name with no edits.
#
##################################################################################################################

DRY_RUN=false
NAME="$(basename "$0")"

# ── Inlined helpers (kept in step with /usr/local/lib/kiro-common.sh) ─────────
if command -v tput >/dev/null 2>&1 && [[ -t 1 ]]; then
    RED="$(tput setaf 1)";    GREEN="$(tput setaf 2)"
    YELLOW="$(tput setaf 3)"; BLUE="$(tput setaf 4)"
    CYAN="$(tput setaf 6)";   BOLD="$(tput bold)"
    RESET="$(tput sgr0)"
else
    RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; RESET=""
fi

log_section() {
    echo
    echo "${GREEN}################################################################################${RESET}"
    echo "${BOLD}${GREEN}$1${RESET}"
    echo "${GREEN}################################################################################${RESET}"
    echo
}
log_info()    { echo "${BLUE}ℹ ${1}${RESET}"; }
log_success() { echo "${GREEN}✓ ${1}${RESET}"; }

show_help() {
    cat <<EOF
${BOLD}${GREEN}${NAME}${RESET} - Copy /etc/skel to home, backing up only the configs it overwrites

${BOLD}Usage:${RESET}
    ${NAME} [--help] [--version] [--dry-run]

${BOLD}Options:${RESET}
    -h, --help          Show this help message and exit
    -v, --version       Show version information and exit
    -d, --dry-run       Show what would be done without making changes

${BOLD}Examples:${RESET}
    ${NAME} --dry-run
    ${NAME}

For a full ~/.config backup instead, use kiro-skell-all.
EOF
}

show_version() {
    local resolved pkg
    resolved="$(realpath "$0" 2>/dev/null || echo "$0")"
    if pkg="$(pacman -Qqo "${resolved}" 2>/dev/null)" && [[ -n "${pkg}" ]]; then
        pacman -Q "${pkg}"
    else
        echo "${NAME} (not installed via pacman)"
    fi
}

execute_or_dryrun() {
    local description="$1"; shift
    if [[ "${DRY_RUN}" == "true" ]]; then
        log_info "[DRY-RUN] Would execute: ${description}"
        log_info "[DRY-RUN] Command: $*"
    else
        "$@"
    fi
}

on_error() {
    echo
    echo "${RED}ERROR on line ${1}: ${2:-}${RESET}" >&2
    sleep 10
}
trap 'on_error "$LINENO" "$BASH_COMMAND"' ERR

main() {
    for arg in "$@"; do
        case "$arg" in
            -h|--help)
                show_help
                exit 0
                ;;
            -v|--version)
                show_version
                exit 0
                ;;
            -d|--dry-run)
                DRY_RUN=true
                log_info "Dry-run mode enabled — no changes will be made"
                ;;
            *)
                echo "${RED}Unknown option: $arg${RESET}" >&2
                exit 1
                ;;
        esac
    done

    log_section "${NAME} — restore default configuration from /etc/skel (fast backup)"
    echo "${NAME} copies /etc/skel to your home directory after backing up only the"
    echo "configs it is about to overwrite — not your entire ~/.config."
    echo
    echo "New configurations often end up in /etc/skel — ${NAME} brings them into use."
    echo
    echo "It backs up each ~/.config entry that /etc/skel/.config contains (date/time"
    echo "stamped), then overwrites your configs with everything in /etc/skel."
    echo
    echo "For a full ~/.config backup instead, use kiro-skell-all."
    echo
    echo "Useful when a tiling WM is crashing — run ${NAME} in a terminal or TTY to recover."
    echo

    if [[ "$DRY_RUN" == "false" ]]; then
        read -rp "Can we copy/paste the content from /etc/skel to your home directory? (y/n) " response
        if [[ "$response" != [yY] ]]; then
            log_info "Nothing has been changed."
            return
        fi
    fi

    local time backup_dir
    time=$(date +%Y.%m.%d-%H.%M.%S)
    backup_dir="$HOME/.config-backup-$time"
    [[ -d ~/.config ]] || mkdir ~/.config

    # ── Scoped backup: only the ~/.config entries /etc/skel will overwrite ────
    if [[ -d /etc/skel/.config ]]; then
        log_info "Backing up only the configs /etc/skel overwrites to ${backup_dir}"
        execute_or_dryrun "Create backup dir ${backup_dir}" mkdir -p "$backup_dir/.config"
        for entry in /etc/skel/.config/*; do
            local name
            name="$(basename "$entry")"
            if [[ -e "$HOME/.config/$name" ]]; then
                log_info "  backing up ~/.config/$name"
                execute_or_dryrun "Backup ~/.config/$name" cp -Rf "$HOME/.config/$name" "$backup_dir/.config/"
            fi
        done
    else
        log_info "No /etc/skel/.config found — nothing to back up"
    fi

    # ── Overwrite all: copy everything in /etc/skel into home ─────────────────
    log_info "Copying /etc/skel to home — be patient"
    execute_or_dryrun "Copy /etc/skel to $HOME" cp -r /etc/skel/. "$HOME"

    log_success "${NAME} done"
}

main "$@"
