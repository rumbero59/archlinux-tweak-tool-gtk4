#!/bin/bash
set -euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://kiroproject.be
# Youtube   : https://youtube.com/erikdubois
##################################################################################################################

RESET=$(tput sgr0)
CYAN=$(tput setaf 6)
GREEN=$(tput setaf 2)
RED=$(tput setaf 1)
YELLOW=$(tput setaf 3)

separator() {
    echo "${CYAN}===============================================================================${RESET}"
}

header() {
    echo ""
    separator
    echo "${CYAN}  $1${RESET}"
    separator
}

success() { echo "${GREEN}  ✓ $1${RESET}"; }
info()    { echo "    $1"; }
warn()    { echo "${YELLOW}  ⚠ $1${RESET}"; }
error()   { echo "${RED}  ✗ $1${RESET}"; }
trap 'error "Command failed at line $LINENO"' ERR

Online=0

# ── Header ─────────────────────────────────────────────────────────────────────
header "Fix Pacman Databases and Keys"

# ── Internet check ─────────────────────────────────────────────────────────────
header "Checking Internet Connectivity"
if ping -c 1 8.8.8.8 > /dev/null 2>&1; then
    success "Internet connection available"
    Online=1
else
    warn "No internet connection — skipping keyring download"
fi

# ── Install latest keyring (online only) ──────────────────────────────────────
if [[ $Online -eq 1 ]]; then
    header "Installing Latest archlinux-keyring"
    info "Downloading and installing from repos..."
    sudo pacman -Sy archlinux-keyring --noconfirm
fi

# ── Remove pacman databases ───────────────────────────────────────────────────
header "Removing Pacman Databases"
info "Target: /var/lib/pacman/sync/*"
sudo rm -f /var/lib/pacman/sync/*
success "Pacman databases removed"

# ── Clear gnupg folder ────────────────────────────────────────────────────────
header "Clearing Pacman GnuPG Folder"
info "Target: /etc/pacman.d/gnupg/*"
sudo rm -rf /etc/pacman.d/gnupg/*
success "GnuPG folder cleared"

# ── Initialize pacman keys ────────────────────────────────────────────────────
header "Initializing Pacman Keys"
sudo pacman-key --init
success "Keys initialized"

# ── Populate keyring ──────────────────────────────────────────────────────────
header "Populating Keyring"
sudo pacman-key --populate
success "Keyring populated"

# ── Add Ubuntu keyserver ──────────────────────────────────────────────────────
header "Adding Ubuntu Keyserver"
info "Appending to /etc/pacman.d/gnupg/gpg.conf..."
echo "keyserver hkp://keyserver.ubuntu.com:80" | sudo tee --append /etc/pacman.d/gnupg/gpg.conf > /dev/null
success "Keyserver added to gpg.conf"

# ── Refresh databases ─────────────────────────────────────────────────────────
header "Refreshing Package Databases"
if [[ $Online -eq 1 ]]; then
    sudo pacman -Sy
else
    warn "No internet connection — skipping database refresh"
fi

# ── Done ──────────────────────────────────────────────────────────────────────
success "Done — you can close this window"
read -rp "Press Enter to close..."
