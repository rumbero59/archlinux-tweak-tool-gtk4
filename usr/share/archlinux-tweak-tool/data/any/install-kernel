#!/bin/bash
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://www.erikdubois.be
##################################################################################################################
# Usage: install-kernel <pkg> <headers>
##################################################################################################################

PKG=${1}
HEADERS=${2}

tput setaf 6
echo "================================================================"
echo "  Installing kernel: $PKG"
echo "  Headers: $HEADERS"
echo "================================================================"
tput sgr0

pacman -S "$PKG" "$HEADERS" --noconfirm --needed

echo
tput setaf 2
echo "================================================================"
echo "  Done installing $PKG"
echo "================================================================"
tput sgr0
echo
echo "###############################################################################"
echo "###                DONE - YOU CAN CLOSE THIS WINDOW                        ####"
echo "###############################################################################"
