#!/bin/bash
set -euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://kiroproject.be
# Youtube   : https://youtube.com/erikdubois
##################################################################################################################

RESET=$(tput sgr0)
CYAN=$(tput setaf 6)
GREEN=$(tput setaf 2)
RED=$(tput setaf 1)
YELLOW=$(tput setaf 3)

separator() {
    echo "${CYAN}===============================================================================${RESET}"
}

header() {
    echo ""
    separator
    echo "${CYAN}  $1${RESET}"
    separator
}

success() { echo "${GREEN}  ✓ $1${RESET}"; }
info()    { echo "    $1"; }
warn()    { echo "${YELLOW}  ⚠ $1${RESET}"; }
error()   { echo "${RED}  ✗ $1${RESET}"; }

# ── Connectivity check ────────────────────────────────────────────────────────
header "Checking Internet Connectivity"

Online=0
if ping -c 1 8.8.8.8 > /dev/null 2>&1; then
    success "You are online"
    Online=1
else
    warn "Not connected to the internet"
    info "Cannot download the latest archlinux-keyring package"
    info "Make sure you are online to retrieve packages"
    Online=0
fi

# ── Install latest archlinux-keyring ─────────────────────────────────────────
if [ "$Online" -eq 1 ]; then
    header "Installing Latest archlinux-keyring"
    sudo pacman -Sy archlinux-keyring --noconfirm
    success "archlinux-keyring installed"
fi

# ── Remove pacman databases ───────────────────────────────────────────────────
header "Removing Pacman Databases"
info "Target: /var/lib/pacman/sync/*"
sudo rm -f /var/lib/pacman/sync/*
success "Pacman databases removed"

# ── Remove gnupg folder ───────────────────────────────────────────────────────
header "Removing /etc/pacman.d/gnupg"
info "Target: /etc/pacman.d/gnupg/*"
sudo rm -rf /etc/pacman.d/gnupg/*
success "gnupg folder cleared"

# ── Initialize pacman keys ────────────────────────────────────────────────────
header "Initializing Pacman Keys"
sudo pacman-key --init
success "pacman-key --init complete"

# ── Populate keyring ──────────────────────────────────────────────────────────
header "Populating Keyring"
sudo pacman-key --populate
success "pacman-key --populate complete"

# ── Add Ubuntu keyserver ──────────────────────────────────────────────────────
header "Adding Ubuntu Keyserver to gpg.conf"
info "Target: /etc/pacman.d/gnupg/gpg.conf"
echo "
keyserver hkp://keyserver.ubuntu.com:80" | sudo tee --append /etc/pacman.d/gnupg/gpg.conf > /dev/null
success "Keyserver added"

# ── Refresh databases ─────────────────────────────────────────────────────────
header "Refreshing Package Databases"
sudo pacman -Sy
success "Package databases refreshed"

# ── Done ──────────────────────────────────────────────────────────────────────
echo ""
separator
echo "${GREEN}  DONE — you can close this window${RESET}"
separator
echo ""
